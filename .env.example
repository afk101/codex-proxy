# 必需: 上游 OpenAI 兼容 API 的密钥
OPENAI_API_KEY="sk-your-openai-api-key-here"

# 可选: 上游 API 基础地址 (默认: https://api.openai.com/v1)
OPENAI_BASE_URL="https://api.openai.com/v1"

# 可选: 代理自身的 API 密钥验证
# 设置后，客户端必须提供此密钥才能访问代理
PROXY_API_KEY="your-proxy-api-key"

# 可选: 服务器设置
HOST="0.0.0.0"
PORT="9002"
LOG_LEVEL="INFO"
# DEBUG, INFO, WARNING, ERROR, CRITICAL

# 可选: 性能设置
REQUEST_TIMEOUT="90"
# 流式读取超时（秒），默认 300
READ_TIMEOUT="300"
MAX_RETRIES="2"

# 自定义请求头配置
# 格式: CUSTOM_HEADER_KEY=header_value
# 这些请求头会自动包含在发往上游 API 的请求中
# CUSTOM_HEADER_ACCEPT="application/json"
# CUSTOM_HEADER_USER_AGENT="node-fetch"
